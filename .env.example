# Copy this file to .env and set your MySQL password
# cp .env.example .env   (or copy manually on Windows)

MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=task_management

# XAMPP default is usually an empty password above.
# If login fails with "Access denied", set the password you use in phpMyAdmin.
